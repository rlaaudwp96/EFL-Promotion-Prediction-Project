import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.linear_model import LinearRegression
from sklearn.preprocessing import PolynomialFeatures
from sklearn.metrics import r2_score

# 1. Load Data
# Using the processed csv file generated from BigQuery
df = pd.read_csv('efl_promotion_teams - seasonal_stats.csv')

# --- PART 1: EDA (Exploratory Data Analysis) ---
print("--- [EDA] Data Exploration & Visualization ---")

# (1) Correlation Heatmap: Which stats impact points the most?
plt.figure(figsize=(10, 8))
corr_cols = ['Total_Points', 'Total_GF', 'Total_GA', 'Avg_SOT', 'Avg_Corners']
corr = df[corr_cols].corr()
sns.heatmap(corr, annot=True, cmap='RdBu', fmt=".2f")
plt.title('Correlation: Match Stats vs. Total Points')
plt.show()

# (2) Scatter Plot: Relationship between Shots on Target and Points
plt.figure(figsize=(8, 6))
sns.scatterplot(data=df, x='Avg_SOT', y='Total_Points', hue='Season', alpha=0.5)
plt.title('Average SOT vs. Total Points')
plt.show()

# --- PART 2: Machine Learning (Supervised Learning - Regression) ---
print("\n--- [ML] Supervised Learning: Regression Model ---")

# Data Splitting: Train on historical data, predict on the 2024/25 season
train_df = df[df['Season'] != '2024/25'].dropna()
test_df = df[df['Season'] == '2024/25'].dropna()

# Define Features (X) and Target (y)
features = ['Total_GF', 'Total_GA', 'Avg_SOT', 'Avg_Corners']
X_train = train_df[features]
y_train = train_df['Total_Points']

# 2-1. Multiple Linear Regression (MLR)
mlr = LinearRegression()
mlr.fit(X_train, y_train)

# Check Model Accuracy (R-squared)
mlr_r2 = r2_score(y_train, mlr.predict(X_train))
print(f"MLR Model Accuracy (R-squared): {mlr_r2:.4f}")

# --- PART 3: Prediction (Who will be promoted in 24/25?) ---
print("\n--- [Prediction] 2024/25 Season Promotion Candidates ---")

# Apply the trained model to current season data
test_df['Predicted_Points'] = mlr.predict(test_df[features])

# Extract Top 5 Teams based on predicted points
top_teams = test_df.sort_values('Predicted_Points', ascending=False).head(5)
print(top_teams[['Team', 'Total_Points', 'Predicted_Points']])

# Visualize Final Predictions
plt.figure(figsize=(10, 6))
sns.barplot(data=top_teams, x='Predicted_Points', y='Team', hue='Team', palette='viridis', legend=False)
plt.title('Top 5 Predicted Teams for Promotion (2024/25)')
plt.xlabel('Predicted Final Points')
plt.show()
